<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Violence Investigation Agent</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --page:#f4f6f9;--white:#fff;--surface:#f9fafb;
  --border:#e2e6ea;--border2:#cbd2da;
  --blue:#2563eb;--blue-lt:#eff4ff;--blue-mid:#dbeafe;
  --purple:#6d28d9;--purple-lt:#f4f0ff;--purple-mid:#ede9fe;
  --red:#dc2626;--red-lt:#fef2f2;--red-mid:#fecaca;
  --amber:#b45309;--amber-lt:#fffbeb;--amber-mid:#fde68a;
  --green:#15803d;--green-lt:#f0fdf4;--green-mid:#bbf7d0;
  --text:#1a1f2e;--muted:#64748b;--subtle:#94a3b8;
  --r:8px;--rl:11px;
}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--page);color:var(--text);min-height:100vh;font-size:13px;line-height:1.5}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-thumb{background:#cbd2da;border-radius:10px}
/* header */
.hdr{height:52px;background:var(--white);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 20px;gap:14px;position:sticky;top:0;z-index:300}
.hdr-icon{width:28px;height:28px;background:var(--blue);border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:13px;color:#fff;flex-shrink:0}
.hdr-name{font-size:13px;font-weight:700}.hdr-sub{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.3px}
.hdr-sep{width:1px;height:22px;background:var(--border)}
.hdr-ctx{flex:1;min-width:0}
.hdr-ctx-title{font-size:11px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.hdr-ctx-sub{font-size:10px;color:var(--muted)}
.hdr-right{display:flex;align-items:center;gap:8px;flex-shrink:0}
.save-chip{font-size:10px;color:var(--green);background:var(--green-lt);border:1px solid var(--green-mid);border-radius:20px;padding:3px 9px;transition:.3s}
.save-chip.saving{color:var(--amber);background:var(--amber-lt);border-color:var(--amber-mid)}
.user-pill{display:flex;align-items:center;gap:7px;background:var(--surface);border:1px solid var(--border);border-radius:7px;padding:4px 10px}
.av{width:22px;height:22px;background:var(--blue);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;color:#fff;flex-shrink:0}
/* views */
.view{display:none}.view.show{display:block}
/* buttons */
.btn{display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border-radius:var(--r);border:1px solid var(--border);cursor:pointer;font-size:12px;font-weight:600;transition:.15s;white-space:nowrap;font-family:inherit;background:var(--white);color:var(--muted)}
.btn:active{transform:scale(.98)}
.btn-primary{background:var(--blue);color:#fff;border-color:var(--blue)}.btn-primary:hover{background:#1d4ed8;color:#fff;border-color:#1d4ed8}
.btn-ghost{background:transparent;border-color:var(--border);color:var(--muted)}.btn-ghost:hover{border-color:var(--blue);color:var(--blue)}
.btn-success{background:var(--green);color:#fff;border-color:var(--green)}
.btn-danger{background:var(--red);color:#fff;border-color:var(--red)}
.btn-danger-o{background:transparent;border-color:var(--red-mid);color:var(--red)}.btn-danger-o:hover{background:var(--red-lt)}
.btn-warn{background:#d97706;color:#fff;border-color:#d97706}
.btn-ai{background:var(--purple);color:#fff;border-color:var(--purple)}.btn-ai:hover{background:#5b21b6;color:#fff}
.btn-sm{padding:5px 11px;font-size:11px}.btn-xs{padding:3px 8px;font-size:10px;border-radius:5px}
/* badges/tags */
.badge{display:inline-flex;align-items:center;padding:2px 7px;border-radius:20px;font-size:10px;font-weight:600;border:1px solid}
.b-red{background:var(--red-lt);color:var(--red);border-color:var(--red-mid)}
.b-amber{background:var(--amber-lt);color:var(--amber);border-color:var(--amber-mid)}
.b-green{background:var(--green-lt);color:var(--green);border-color:var(--green-mid)}
.b-blue{background:var(--blue-lt);color:var(--blue);border-color:var(--blue-mid)}
.b-gray{background:var(--surface);color:var(--muted);border-color:var(--border)}
.tag{display:inline-flex;align-items:center;padding:1px 5px;border-radius:4px;font-size:9px;font-weight:700;border:1px solid}
.t-src{background:var(--green-lt);color:var(--green);border-color:var(--green-mid)}
.t-ai{background:var(--purple-lt);color:var(--purple);border-color:var(--purple-mid)}
.t-mgr{background:var(--blue-lt);color:var(--blue);border-color:var(--blue-mid)}
.t-req{background:var(--red-lt);color:var(--red);border-color:var(--red-mid);font-size:8px}
.t-opt{background:var(--surface);color:var(--subtle);border-color:var(--border);font-size:8px}
/* alerts */
.alert{display:flex;align-items:flex-start;gap:10px;border-radius:var(--r);padding:10px 13px;margin-bottom:12px;font-size:12px;line-height:1.5;border:1px solid}
.al-red{background:var(--red-lt);border-color:var(--red-mid);color:#7f1d1d}
.al-amber{background:var(--amber-lt);border-color:var(--amber-mid);color:#78350f}
.al-blue{background:var(--blue-lt);border-color:var(--blue-mid);color:#1e3a8a}
.al-green{background:var(--green-lt);border-color:var(--green-mid);color:#14532d}
.al-purple{background:var(--purple-lt);border-color:var(--purple-mid);color:#4c1d95}
.al-icon{font-size:14px;flex-shrink:0;margin-top:1px}
.al-dismiss{margin-left:auto;background:transparent;border:none;color:var(--muted);cursor:pointer;font-size:16px;line-height:1;padding:0 2px}
/* cards */
.card{background:var(--white);border:1px solid var(--border);border-radius:var(--rl);padding:16px 18px;margin-bottom:14px}
.card-sm{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:12px 14px}
.divider{height:1px;background:var(--border);margin:14px 0}
.sec-title{font-size:13px;font-weight:700}
.sec-desc{font-size:11px;color:var(--muted);margin-bottom:14px;line-height:1.6}
/* form */
.field{margin-bottom:12px}
.field-label{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--muted);margin-bottom:4px;font-weight:600}
.field input,.field textarea,.field select{width:100%;background:var(--white);border:1px solid var(--border);border-radius:var(--r);color:var(--text);padding:7px 10px;font-size:12px;font-family:inherit;transition:.15s}
.field input:focus,.field textarea:focus,.field select:focus{outline:none;border-color:var(--blue);box-shadow:0 0 0 3px rgba(37,99,235,.08)}
.field textarea{resize:vertical;min-height:68px;line-height:1.6}
.field.mgr input,.field.mgr textarea,.field.mgr select{border-left:3px solid var(--blue)}
.field.ai-field textarea{border-left:3px solid var(--purple)}
.ro{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:7px 10px;font-size:12px;color:var(--text);line-height:1.6;min-height:32px}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
/* checklist */
.chk{display:flex;align-items:flex-start;gap:9px;padding:8px 11px;background:var(--white);border-radius:var(--r);border:1px solid var(--border);margin-bottom:6px;cursor:pointer;transition:.15s}
.chk:hover{border-color:var(--border2)}.chk.ck{border-color:var(--green-mid);background:var(--green-lt)}
.chk input[type=checkbox]{accent-color:var(--green);width:14px;height:14px;margin-top:1px;flex-shrink:0;cursor:pointer}
.chk-lbl{font-size:12px;flex:1;line-height:1.5}.chk-lbl small{display:block;font-size:10px;color:var(--muted);margin-top:1px}
/* ai */
.ai-box{background:var(--purple-lt);border:1px solid var(--purple-mid);border-radius:var(--rl);padding:14px;margin-top:10px}
.ai-hdr{display:flex;align-items:center;gap:8px;margin-bottom:10px;font-size:11px;font-weight:700;color:var(--purple)}
.ai-box textarea{width:100%;background:var(--white);border:1px solid var(--purple-mid);border-radius:var(--r);padding:10px;color:var(--text);font-size:11px;line-height:1.75;font-family:'Courier New',monospace;min-height:180px;resize:vertical}
.ai-cta{display:flex;align-items:center;gap:12px;background:var(--purple-lt);border:1px solid var(--purple-mid);border-radius:var(--rl);padding:13px 15px;margin-bottom:14px}
.ai-cta-title{font-size:12px;font-weight:700;color:var(--purple);margin-bottom:2px}
.ai-cta-sub{font-size:11px;color:var(--muted)}
.loading{display:flex;align-items:center;gap:9px;color:var(--purple);font-size:12px;padding:12px 0}
.spinner{width:15px;height:15px;border:2px solid var(--purple-mid);border-top-color:var(--purple);border-radius:50%;animation:spin .7s linear infinite;flex-shrink:0}
@keyframes spin{to{transform:rotate(360deg)}}
.legend-bar{display:flex;align-items:center;gap:16px;background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:7px 12px;margin-bottom:14px;font-size:10px;color:var(--muted);flex-wrap:wrap}
.lg-item{display:flex;align-items:center;gap:5px}
.lg-line{width:12px;height:3px;border-radius:2px}
/* upload */
.upload-zone{border:2px dashed var(--border2);border-radius:var(--rl);padding:22px;text-align:center;cursor:pointer;transition:.2s;background:var(--surface)}
.upload-zone:hover,.upload-zone.drag{border-color:var(--blue);background:var(--blue-lt)}
.upload-zone.done{border-color:var(--green);border-style:solid;background:var(--green-lt)}
/* training table */
.tt{width:100%;border-collapse:collapse;font-size:12px}
.tt th{text-align:left;padding:7px 10px;background:var(--surface);color:var(--muted);font-size:10px;font-weight:700;letter-spacing:.4px;border-bottom:1px solid var(--border)}
.tt td{padding:8px 10px;border-bottom:1px solid var(--border);vertical-align:middle}
.tt tr:last-child td{border-bottom:none}
/* sequence */
.seq-item{display:flex;gap:10px;margin-bottom:8px}
.seq-time{width:68px;flex-shrink:0}
.seq-time input{width:100%;background:var(--white);border:1px solid var(--border);border-radius:var(--r);color:var(--text);padding:6px 7px;font-size:11px;text-align:center;font-family:inherit}
.seq-dot{display:flex;flex-direction:column;align-items:center;flex-shrink:0}
.seq-circle{width:9px;height:9px;border-radius:50%;background:var(--blue);flex-shrink:0;margin-top:10px}
.seq-line{width:2px;flex:1;background:var(--border);margin:3px auto}
.seq-body textarea{width:100%;background:var(--white);border:1px solid var(--border);border-left:3px solid var(--purple);border-radius:var(--r);color:var(--text);padding:7px 10px;font-size:12px;font-family:inherit;min-height:46px;resize:vertical;line-height:1.5}
/* env checklist with yes/no/na */
.env-list{display:flex;flex-direction:column;gap:6px;margin-bottom:12px}
.env-row{display:flex;align-items:center;gap:12px;padding:10px 12px;background:var(--white);border:1px solid var(--border);border-radius:var(--r);transition:.15s}
.env-row:hover{border-color:var(--border2)}
.env-text{flex:1;min-width:0}
.env-label{font-size:12px;color:var(--text);line-height:1.4}
.env-hint{font-size:10px;color:var(--muted);margin-top:2px}
.env-choices{display:flex;gap:4px;flex-shrink:0}
.env-btn{padding:5px 12px;font-size:11px;font-weight:600;border:1px solid var(--border);background:var(--white);color:var(--muted);cursor:pointer;border-radius:var(--r);font-family:inherit;min-width:50px;transition:.12s}
.env-btn:hover{border-color:var(--border2);color:var(--text)}
.env-btn.env-sel-yes{background:var(--green-lt);border-color:var(--green);color:var(--green)}
.env-btn.env-sel-no{background:var(--red-lt);border-color:var(--red);color:var(--red)}
.env-btn.env-sel-na{background:#e0e7ef;border-color:#94a3b8;color:#475569}

/* contributing factors */
.cf-list{display:flex;flex-direction:column;gap:14px}
.cf-group{background:var(--white);border:1px solid var(--border);border-radius:var(--rl);overflow:hidden}
.cf-group-hdr{background:var(--surface);padding:8px 14px;font-size:11px;font-weight:700;color:var(--text);letter-spacing:.3px;border-bottom:1px solid var(--border)}
.cf-items{padding:6px 8px;display:grid;grid-template-columns:1fr 1fr;gap:2px}
@media(max-width:760px){.cf-items{grid-template-columns:1fr}}
.cf-check{display:flex;align-items:flex-start;gap:9px;padding:8px 10px;border-radius:6px;cursor:pointer;font-size:12px;line-height:1.45;color:var(--text);transition:.12s}
.cf-check:hover{background:var(--surface)}
.cf-check.cf-checked{background:var(--blue-lt)}
.cf-check input[type=checkbox]{accent-color:var(--blue);width:14px;height:14px;margin-top:2px;flex-shrink:0;cursor:pointer}
.cf-check span{flex:1}
.cf-ai-mark{display:inline-block;font-size:9px;color:var(--purple);background:var(--purple-lt);border:1px solid var(--purple-mid);padding:1px 5px;border-radius:4px;font-weight:700;margin-left:4px;vertical-align:middle}
.cf-item{background:var(--white);border:1px solid var(--border);border-radius:var(--rl);padding:12px 14px;margin-bottom:8px}
.cf-top{display:flex;align-items:center;gap:10px;margin-bottom:8px;flex-wrap:wrap}
.cf-name{font-size:12px;font-weight:600;flex:1}
.cf-sel{background:var(--white);border:1px solid var(--border);border-radius:var(--r);color:var(--text);padding:4px 8px;font-size:11px;cursor:pointer}
.cf-ai{font-size:11px;line-height:1.7;color:#4c1d95;background:var(--purple-lt);border:1px solid var(--purple-mid);border-left:3px solid var(--purple);border-radius:var(--r);padding:8px 10px;margin-bottom:8px}
.cf-mgr{width:100%;background:var(--white);border:1px solid var(--border);border-left:3px solid var(--blue);border-radius:var(--r);color:var(--text);padding:7px 10px;font-size:11px;font-family:inherit;min-height:44px;resize:vertical;line-height:1.5}
/* corrective actions - simplified two-column */
.ca-card-simple{background:var(--white);border:1px solid var(--border);border-radius:var(--rl);padding:14px 16px;margin-bottom:10px;position:relative;display:flex;gap:12px;transition:.15s}
.ca-card-simple:hover{border-color:var(--border2)}
.ca-num-circle{width:26px;height:26px;background:var(--blue);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;flex-shrink:0;margin-top:2px}
.ca-content{flex:1;display:grid;grid-template-columns:1.6fr 1fr;gap:14px;min-width:0}
.ca-action-side{display:flex;flex-direction:column;min-width:0}
.ca-reason-side{display:flex;flex-direction:column;min-width:0;padding-left:14px;border-left:1px dashed var(--border)}
.ca-side-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:5px;gap:8px;flex-wrap:wrap}
.ca-side-label{font-size:10px;font-weight:700;color:var(--text);letter-spacing:.4px;text-transform:uppercase}
.ca-reason-label{color:var(--muted)}
.ca-copy-hint{font-size:9px;color:var(--blue);font-weight:600}
.ca-ref-tag{font-size:9px;color:var(--subtle);font-style:italic}
.ca-details{width:100%;background:var(--white);border:1px solid var(--border);border-radius:var(--r);color:var(--text);padding:9px 11px;font-size:12px;line-height:1.6;font-family:inherit;resize:vertical;transition:.15s;min-height:80px}
.ca-details:focus{outline:none;border-color:var(--blue);box-shadow:0 0 0 3px rgba(37,99,235,.08)}
.ca-copy-btn{margin-top:7px;align-self:flex-start}
.ca-reason-box{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:9px 11px;font-size:11px;line-height:1.6;color:var(--muted);min-height:80px;flex:1}
.ca-source-note{font-size:9px;color:var(--subtle);margin-top:6px;font-weight:600}
.ca-del-btn{position:absolute;top:10px;right:10px;background:transparent;border:none;color:var(--subtle);cursor:pointer;font-size:18px;padding:2px 8px;border-radius:4px;line-height:1;transition:.12s}
.ca-del-btn:hover{color:var(--red);background:var(--red-lt)}

@media(max-width:760px){
  .ca-content{grid-template-columns:1fr;gap:10px}
  .ca-reason-side{padding-left:0;border-left:none;border-top:1px dashed var(--border);padding-top:10px}
}

/* corrective actions - legacy */
.ca-card{background:var(--white);border:1px solid var(--border);border-radius:var(--rl);padding:12px 14px;margin-bottom:8px;position:relative}
.ca-hdr{display:flex;align-items:flex-start;gap:10px;margin-bottom:10px}
.ca-num{width:22px;height:22px;background:var(--blue);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff;flex-shrink:0;margin-top:3px}
.ca-source{font-size:9px;color:var(--purple);font-weight:700;margin-bottom:4px}
.ca-meta{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:8px}
.ca-meta select,.ca-meta input[type=date]{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:var(--r);color:var(--text);padding:5px 7px;font-size:11px;font-family:inherit}
.ca-meta label{font-size:9px;color:var(--muted);font-weight:700;display:block;margin-bottom:3px}
.ca-del{position:absolute;top:10px;right:10px;background:transparent;border:none;color:var(--subtle);cursor:pointer;font-size:14px;padding:2px 6px;border-radius:4px}
.ca-del:hover{color:var(--red);background:var(--red-lt)}
/* dashboard */
.dash{padding:22px 24px;max-width:1040px;margin:0 auto}
.tab-bar{display:flex;gap:0;border-bottom:1px solid var(--border);margin-bottom:20px}
.tab-btn{padding:9px 16px;font-size:12px;font-weight:600;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;transition:.15s;background:transparent;border-top:none;border-left:none;border-right:none;font-family:inherit}
.tab-btn:hover{color:var(--text)}.tab-btn.active{color:var(--blue);border-bottom-color:var(--blue)}
.tab-pane{display:none}.tab-pane.show{display:block}
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:20px}
.stat{background:var(--white);border:1px solid var(--border);border-radius:var(--rl);padding:14px 16px;border-top:3px solid}
.stat-num{font-size:24px;font-weight:800;line-height:1.1;margin-bottom:2px}
.stat-lbl{font-size:11px;color:var(--muted)}.stat-hint{font-size:10px;color:var(--subtle);margin-top:2px}
.filters{display:flex;gap:5px;flex-wrap:wrap}
.f-btn{padding:4px 11px;border-radius:20px;font-size:11px;font-weight:600;cursor:pointer;border:1px solid var(--border);color:var(--muted);background:var(--white);transition:.15s;font-family:inherit}
.f-btn:hover{border-color:var(--border2)}.f-btn.active{background:var(--blue);color:#fff;border-color:var(--blue)}
.inc-grid{display:flex;flex-direction:column;gap:8px}
.inc{background:var(--white);border:1px solid var(--border);border-radius:var(--rl);overflow:hidden;display:flex;transition:border-color .15s,box-shadow .15s}
.inc:hover{border-color:var(--border2);box-shadow:0 2px 8px rgba(0,0,0,.06)}
.inc.od{border-color:var(--red-mid)}.inc.urg{border-color:var(--amber-mid)}
.inc-stripe{width:4px;flex-shrink:0}
.inc-stripe.r{background:var(--red)}.inc-stripe.a{background:#d97706}
.inc-stripe.b{background:var(--blue)}.inc-stripe.g{background:var(--green)}
.inc-body{flex:1;padding:13px 15px}
.inc-hdr{display:flex;align-items:flex-start;justify-content:space-between;gap:10px;margin-bottom:6px}
.inc-id{font-size:10px;color:var(--muted);font-weight:600;letter-spacing:.4px;margin-bottom:2px}
.inc-title{font-size:13px;font-weight:700}
.inc-badges{display:flex;gap:5px;flex-wrap:wrap;flex-shrink:0;padding-top:2px}
.inc-summary{font-size:11px;color:var(--muted);line-height:1.6;margin-bottom:8px;background:var(--surface);border-radius:var(--r);padding:7px 9px;border-left:3px solid var(--border2)}
.inc-meta{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:8px}
.inc-meta span{font-size:11px;color:var(--muted)}
.deadlines{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:9px}
.dl{display:flex;align-items:center;gap:4px;padding:3px 8px;border-radius:6px;font-size:10px;font-weight:600;border:1px solid}
.dl-r{background:var(--red-lt);border-color:var(--red-mid);color:var(--red)}
.dl-a{background:var(--amber-lt);border-color:var(--amber-mid);color:var(--amber)}
.dl-g{background:var(--green-lt);border-color:var(--green-mid);color:var(--green)}
.dl-x{background:var(--surface);border-color:var(--border);color:var(--muted)}
.prog-wrap{margin-bottom:9px}
.prog-row{display:flex;justify-content:space-between;font-size:10px;color:var(--muted);margin-bottom:3px}
.prog-track{background:var(--surface);border-radius:20px;height:4px;overflow:hidden;margin-bottom:4px;border:1px solid var(--border)}
.prog-fill{height:100%;border-radius:20px}
.pf-f{background:var(--blue)}
.inc-actions{display:flex;gap:6px;flex-wrap:wrap}
.del-card{background:var(--white);border:1px solid var(--border);border-radius:var(--rl);padding:12px 14px;margin-bottom:8px;display:flex;align-items:center;gap:11px}
.del-av{width:32px;height:32px;background:var(--blue-lt);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(--blue);flex-shrink:0}
.del-name{font-size:12px;font-weight:600}.del-email{font-size:11px;color:var(--muted)}.del-role{font-size:10px;color:var(--blue);margin-top:1px}
.search-row{display:flex;gap:8px;margin-bottom:12px}
.search-row input{flex:1;background:var(--white);border:1px solid var(--border);border-radius:var(--r);color:var(--text);padding:8px 11px;font-size:12px;font-family:inherit}
.search-row input:focus{outline:none;border-color:var(--blue);box-shadow:0 0 0 3px rgba(37,99,235,.08)}
/* investigation shell */
.inv-wrap{display:flex;height:calc(100vh - 52px);overflow:hidden}
.inv-sb{width:196px;background:var(--white);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;overflow-y:auto}
.inv-sb-inner{flex:1;padding:10px 6px}
.sb-grp{font-size:9px;font-weight:700;color:var(--subtle);letter-spacing:1px;text-transform:uppercase;padding:0 8px;margin-bottom:4px;margin-top:10px}
.sb-item{display:flex;align-items:center;gap:7px;padding:7px 9px;border-radius:var(--r);cursor:pointer;font-size:11px;font-weight:500;color:var(--muted);transition:.15s;margin-bottom:1px;user-select:none}
.sb-item:hover{background:var(--surface);color:var(--text)}
.sb-item.active{background:var(--blue-lt);color:var(--blue);font-weight:700}
.sb-item.done{color:var(--green)}
.sb-dot{width:17px;height:17px;border-radius:50%;border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:8px;flex-shrink:0;font-weight:700}
.active .sb-dot{border-color:var(--blue);color:var(--blue)}
.done .sb-dot{background:var(--green);border-color:var(--green);color:#fff}
.sb-div{height:1px;background:var(--border);margin:6px 0}
.sb-prog{padding:10px;border-top:1px solid var(--border)}
.sb-prog-bar{background:var(--surface);border:1px solid var(--border);border-radius:20px;height:5px;overflow:hidden;margin-bottom:4px}
.sb-prog-fill{height:100%;background:var(--blue);border-radius:20px;transition:width .4s}
.sb-prog-lbl{font-size:10px;color:var(--muted)}
.inv-main{flex:1;display:flex;flex-direction:column;overflow:hidden;background:var(--page)}
.inv-topbar{background:var(--white);border-bottom:1px solid var(--border);padding:10px 18px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.inv-topbar h3{font-size:13px;font-weight:700}
.inv-topbar p{font-size:11px;color:var(--muted);margin-top:1px}
.inv-content{flex:1;overflow-y:auto;padding:18px 20px;max-width:860px;width:100%}
/* violence questions table */
.vq-table{width:100%;border-collapse:collapse;border:1px solid var(--border);border-radius:var(--rl);overflow:hidden}
.vq-table th{text-align:left;padding:8px 12px;background:var(--surface);color:var(--muted);font-size:10px;font-weight:700;letter-spacing:.4px;border-bottom:1px solid var(--border)}
.vq-table td{padding:9px 12px;border-bottom:1px solid var(--border);font-size:12px}
.vq-table tr:last-child td{border-bottom:none}
.vq-group{background:var(--surface);font-size:12px;font-weight:700;color:var(--text);padding:8px 12px;border-bottom:1px solid var(--border)}
/* chat */
.chat-history{min-height:100px;display:flex;flex-direction:column;gap:10px;margin-bottom:12px}
.chat-user{display:flex;justify-content:flex-end}
.chat-user-bubble{background:var(--blue-lt);border:1px solid var(--blue-mid);border-radius:var(--rl);padding:9px 13px;max-width:82%;font-size:12px;color:#1e3a8a;line-height:1.6}
.chat-ai-bubble{background:var(--purple-lt);border:1px solid var(--purple-mid);border-radius:var(--rl);padding:10px 13px;max-width:90%;font-size:12px;line-height:1.6}
.chat-label{font-size:9px;font-weight:700;color:var(--purple);margin-bottom:6px;letter-spacing:.3px}
.conf-bar{margin-top:8px;display:flex;align-items:flex-start;gap:7px;padding-top:8px;border-top:1px solid var(--border)}
/* modals */
.modal-wrap{display:none;position:fixed;inset:0;background:rgba(0,0,0,.35);z-index:500;align-items:center;justify-content:center}
.modal-wrap.show{display:flex}
.modal-box{background:var(--white);border:1px solid var(--border);border-radius:var(--rl);padding:24px;max-width:420px;width:100%;margin:20px}
/* toasts */
#toasts{position:fixed;bottom:14px;right:14px;z-index:9999;display:flex;flex-direction:column;gap:5px}
.toast{background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:8px 13px;font-size:12px;box-shadow:0 2px 8px rgba(0,0,0,.1);animation:tin .2s ease;min-width:200px}
.toast.t-s{border-color:var(--green-mid);color:var(--green)}
.toast.t-w{border-color:var(--amber-mid);color:var(--amber)}
.toast.t-i{border-color:var(--blue-mid);color:var(--blue)}
@keyframes tin{from{transform:translateX(20px);opacity:0}to{transform:none;opacity:1}}
@media(max-width:680px){
  .inv-sb{width:44px}.sb-item span:not(.sb-dot){display:none}.sb-grp{display:none}
  .stats{grid-template-columns:1fr 1fr}.grid2{grid-template-columns:1fr}.ca-meta{grid-template-columns:1fr 1fr}
}
</style>
</head>
