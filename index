Training: Both at High plus ATR level. WA refresher overdue.

Security report: ${INC.sec}

WA statement: ${INC.workers[0].stmt}

BK statement: ${INC.workers[1].stmt}`;

  try{
    const msgs=[{role:'user',content:ctx+'\n\nQuestion: '+chatHistory[0].content}];
    for(let i=1;i<chatHistory.length;i++) msgs.push(chatHistory[i]);
    const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:AI_MODEL,max_tokens:1000,messages:msgs})});
    const d=await r.json();
    chatHistory.push({role:'assistant',content:d.content?.[0]?.text||'No response.'});
  }catch(e){
    chatHistory.push({role:'assistant',content:`Error: ${e.message}\nCONFIDENCE: Low \u2014 Could not reach AI service.`});
  }
  document.getElementById('chat-loading')?.remove();
  renderChat();
}

function renderChat(){
  const hist=document.getElementById('chat-hist');if(!hist)return;
  hist.innerHTML=chatHistory.map(m=>{
    if(m.role==='user') return `<div class="chat-user"><div class="chat-user-bubble">${m.content}</div></div>`;
    const lines=m.content.split('\n');
    const ci=lines.findIndex(l=>l.startsWith('CONFIDENCE:'));
    const ai=lines.findIndex(l=>l.startsWith('ASSUMPTIONS:'));
    let body=m.content,confHtml='',asmHtml='';
    const cutIdx=ci>-1?(ai>-1?Math.min(ci,ai):ci):(ai>-1?ai:-1);
    if(cutIdx>-1) body=lines.slice(0,cutIdx).join('\n').trim();
    if(ci>-1){
      const cl=lines[ci].replace('CONFIDENCE:','').trim();
      const lv=cl.startsWith('High')?'High':cl.startsWith('Medium')?'Medium':'Low';
      const cColor=lv==='High'?'var(--green)':lv==='Medium'?'var(--amber)':'var(--red)';
      const cBg=lv==='High'?'var(--green-lt)':lv==='Medium'?'var(--amber-lt)':'var(--red-lt)';
      const cBd=lv==='High'?'var(--green-mid)':lv==='Medium'?'var(--amber-mid)':'var(--red-mid)';
      confHtml=`<div class="conf-bar"><span style="background:${cBg};color:${cColor};border:1px solid ${cBd};padding:2px 8px;border-radius:20px;font-size:10px;font-weight:700;flex-shrink:0">Confidence: ${lv}</span><span style="font-size:10px;color:var(--muted);line-height:1.5">${cl.replace(/^(High|Medium|Low)\s*[\u2014\-]\s*/,'')}</span></div>`;
    }
    if(ai>-1){
      const al=lines[ai].replace('ASSUMPTIONS:','').trim();
      if(al && al.toLowerCase()!=='none'){
        asmHtml=`<div style="margin-top:6px;padding:6px 9px;background:var(--surface);border-radius:6px;font-size:10px;color:var(--muted);line-height:1.5"><strong style="color:var(--text)">Assumptions:</strong> ${al}</div>`;
      }
    }
    return `<div><div class="chat-ai-bubble"><div class="chat-label">&#10022; AI INVESTIGATION ASSISTANT \u00b7 ${AI_MODEL_LABEL.toUpperCase()}</div><div style="white-space:pre-wrap">${body}</div>${confHtml}${asmHtml}</div></div>`;
  }).join('');
  hist.scrollTop=hist.scrollHeight;
}

