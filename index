<div id="toasts"></div>

<script>
/* ── DATA ── */
const INC = {
  workers:[
    {id:'97472',i:'WA',level:'High plus ATR',baseline:'Completed',refresher:'Not Completed',higherTask:'No',
     stmt:'This was during a code white call that I attended. Security had taken the pt down to the ground. I was restraining the pt\'s legs while she was in supine position. Security allowed her to sit up while still on the ground, and then the pt started swearing at me and spat in my face. This landed all over my face, including both eyes.\n\nI was told to leave and wash my face, which I did. I triaged into the ER after.\n\nThe pt was high risk.'},
    {id:'97488',i:'BK',level:'High plus ATR',baseline:'Completed',refresher:'Completed',higherTask:'No',
     stmt:'We had an agitated psychiatric patient that was trying to run away. We tried to verbally de-escalate her, but she started to run towards the exit doors. At that point security stopped her and put her on the floor. We then tried to get her from the floor onto the stretcher at which point she kicked me twice in my left upper quadrant where the ribs are.\n\nSecurity then placed her back down. In the second attempt of securing her I somehow twisted my right ankle, but I was not aware of this until the next day.\n\nI have tenderness and soreness in my left rib area. I have swelling and pain in my right ankle upon movement and weight bearing.'},
  ],
  prelim:['Injured workers offered immediate support and triaged into ER','Scene assessed — no structural damage identified','BBF protocol initiated for WA; BK assessed for rib and ankle injuries'],
  sec:`On Sunday, 12 April 2026, at approximately 1022 hours, Security observed certified patient J.W verbally escalating and exhibiting aggressive behaviour toward Dr S.F. Patient demanded discharge while being assessed.\n\nAt 1023 hours, patient kicked a chair and moved toward EHS interior — Code White initiated.\n\nAt 1025 hours, patient attempted to flee. Security intervened. RPN B.K. secured legs. At 1026 hours, patient actively kicked — right leg struck RPN B.K.'s torso. Patient moved to floor in supine. LPN W.A. assists.\n\nAt 1027 hours, patient spat at LPN W.A. — contact on right side of face and both eyes. Spit mask applied.\n\nAt 1030 hours, 6-point Pinel restraints applied. RPN B.K. sought medical attention. LPN W.A. pressing charges. Security cleared 1039 hours.`,
};

const METAS = [
  {title:'1. Incident details',         meta:'Auto-populated from intake \u00b7 Review and confirm'},
  {title:'2. Training compliance',       meta:'Auto-populated from LMS \u00b7 Review for each worker'},
  {title:'3. Security report',           meta:'Upload PDF \u00b7 AI extracts narrative automatically'},
  {title:'4. Staff statements',          meta:'Auto-populated from PWHCC \u00b7 Add follow-up notes'},
  {title:'5. Witnesses',                 meta:'Record all witness observations'},
  {title:'6. Scene & context',           meta:'Scene observation and contextual factors at time of incident'},
  {title:'7. Sequence of events',        meta:'AI-generated from all inputs \u00b7 Review and edit'},
  {title:'8. Violence context questions',meta:'AI answers standardized questions \u00b7 Manager confirms'},
  {title:'9. Contributing factors',      meta:'AI analysis using best-practice causal reasoning \u00b7 Manager confirms'},
  {title:'10. Corrective actions',        meta:'AI-suggested actions based on contributing factors \u00b7 Edit, copy, finalize'},
  {title:'AI assistant',                 meta:'Ask any question about this investigation \u00b7 AI responds with confidence level'},
];

const TOTAL = 10; // navigable investigation sections (AI assistant is bonus)
let cur = 0;
const done = new Set();
let dirty = false, pendingDest = null, saveTimer;
let chatHistory = [];

/* ── ROUTING ── */
function showView(id){
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('show'));
  document.getElementById('view-'+id).classList.add('show');
  const inv = id==='full';
  document.getElementById('btn-dash').style.display = inv?'':'none';
  document.getElementById('save-chip').style.display = inv?'':'none';
  document.getElementById('hdr-title').textContent = inv?'Full investigation \u2014 INC-97472/97488':'Dashboard';
}
function openFull(){dirty=false;cur=0;showView('full');render();}
function navToDash(){
  if(dirty){pendingDest='dash';document.getElementById('unsaved-modal').classList.add('show');return;}
  showView('dash');
}
function cancelNav(){document.getElementById('unsaved-modal').classList.remove('show');pendingDest=null;}
function confirmNav(){
  document.getElementById('unsaved-modal').classList.remove('show');dirty=false;
  if(pendingDest==='dash') showView('dash');
  else if(pendingDest!==null){cur=pendingDest;render();}
  pendingDest=null;
}
function markDirty(){
  dirty=true;
  const chip=document.getElementById('save-chip');
  chip.classList.add('saving');document.getElementById('save-lbl').textContent='Saving\u2026';
  clearTimeout(saveTimer);
  saveTimer=setTimeout(()=>{dirty=false;chip.classList.remove('saving');document.getElementById('save-lbl').textContent='Saved';},1200);
}
document.addEventListener('input',e=>{if(['INPUT','TEXTAREA','SELECT'].includes(e.target.tagName))markDirty();});

function go(i){
  if(i<0||i>=METAS.length) return;
  if(dirty){pendingDest=i;document.getElementById('unsaved-modal').classList.add('show');return;}
  done.add(cur);cur=i;render();
}

function render(){
  // sidebar
  for(let i=0;i<METAS.length;i++){
    const el=document.getElementById('sb'+i);
    el.className='sb-item'+(i===cur?' active':done.has(i)?' done':'');
    el.querySelector('.sb-dot').textContent=done.has(i)?'\u2713':(i<10?i+1:'\u2736');
  }
  // topbar
  document.getElementById('f-title').textContent=METAS[cur].title;
  document.getElementById('f-meta').textContent=METAS[cur].meta;
  // progress (only count the 10 main sections, not AI assistant)
  const pct=Math.round(((Math.min(cur,TOTAL-1)+1)/TOTAL)*100);
  document.getElementById('f-prog').style.width=pct+'%';
  document.getElementById('f-lbl').textContent=cur<TOTAL?'Section '+(cur+1)+' of '+TOTAL:'AI Assistant';
  // nav buttons
  document.getElementById('f-back').disabled=cur===0;
  document.getElementById('f-next').style.display=cur<TOTAL-1?'':'none';
  document.getElementById('f-submit').style.display=cur===TOTAL-1?'':'none';
  // content
